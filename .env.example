# Pusher Configuration
# Get your credentials from https://dashboard.pusher.com/

# Backend (Netlify Functions)
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=your_cluster

# Frontend (Vite) - copy values from above
VITE_PUSHER_KEY=your_key
VITE_PUSHER_CLUSTER=your_cluster
# Auth endpoint for private channels (Netlify function)
VITE_PUSHER_AUTH_ENDPOINT=/.netlify/functions/pusher-auth